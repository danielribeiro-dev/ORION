# ORION Environment Configuration Example

# Environment (development/production)
ORION_ENV=development

# System Identity
ORION_SYSTEM_NAME=ORION
ORION_USER_NAME=User
ORION_LOG_LEVEL=INFO

# LLM Configuration (Groq)
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# LLM Configuration (Ollama - Local Fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest

# HF_TOKEN: Opcional, para permitir limites maiores no download de modelos
# HF_TOKEN=
